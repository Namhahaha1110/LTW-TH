@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@page "/admin/products"
@page "/admin"
@inherits OwningComponentBase<IStoreRepository>

<div class="d-flex flex-column flex-lg-row justify-content-lg-between align-items-lg-center mb-4 gap-3">
    <div>
        <h3 class="mb-1 fw-semibold"><i class="fa-solid fa-box-open me-2"></i>Product Management</h3>
        <div class="text-muted">Tổng cộng <strong>@TotalProducts</strong> sản phẩm trong hệ thống</div>
    </div>
    <NavLink class="btn btn-primary" href="/admin/products/create">
        <i class="fa-solid fa-plus me-1"></i>Create Product
    </NavLink>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-md-6">
        <div class="border rounded-3 p-3 h-100 bg-white">
            <div class="small text-muted text-uppercase">Số sản phẩm</div>
            <div class="h4 mb-0 fw-semibold">@TotalProducts</div>
        </div>
    </div>
    <div class="col-12 col-md-6">
        <div class="border rounded-3 p-3 h-100 bg-white">
            <div class="small text-muted text-uppercase">Số category</div>
            <div class="h4 mb-0 fw-semibold">@TotalCategories</div>
        </div>
    </div>
</div>

<div class="table-responsive border rounded-3">
    <table class="table align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th style="width: 80px">ID</th>
                <th>Name</th>
                <th style="width: 180px">Category</th>
                <th style="width: 150px">Price</th>
                <th style="width: 230px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (ProductData?.Count() > 0)
            {
                @foreach (Product p in ProductData)
                {
                    <tr>
                        <td>@p.ProductId</td>
                        <td>
                            <div class="fw-semibold">@p.Name</div>
                            <div class="text-muted small text-truncate">@p.Description</div>
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-dark text-white px-3 py-2">@p.Category</span>
                        </td>
                        <td class="fw-semibold">@p.Price.ToString("c")</td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <NavLink class="btn btn-outline-info" href="@GetDetailsUrl(p.ProductId)">
                                    <i class="fa-regular fa-eye me-1"></i>Details
                                </NavLink>
                                <NavLink class="btn btn-outline-warning" href="@GetEditUrl(p.ProductId)">
                                    <i class="fa-regular fa-pen-to-square me-1"></i>Edit
                                </NavLink>
                                <button class="btn btn-outline-danger" @onclick="@(e => DeleteProduct(p))">
                                    <i class="fa-regular fa-trash-can me-1"></i>Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">No Products</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (TotalPages > 1)
{
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mt-3 gap-2">
        <small class="text-muted">Trang @CurrentPage / @TotalPages • Hiển thị @(ProductData?.Count() ?? 0) sản phẩm</small>

        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                <button type="button"
                        class="page-link"
                        disabled="@(CurrentPage == 1)"
                        @onclick="() => ChangePage(CurrentPage - 1)">
                    Previous
                </button>
            </li>

            @foreach (int pageNumber in GetVisiblePages())
            {
                <li class="page-item @(pageNumber == CurrentPage ? "active" : "")">
                    <button type="button"
                            class="page-link"
                            disabled="@(pageNumber == CurrentPage)"
                            @onclick="() => ChangePage(pageNumber)">
                        @pageNumber
                    </button>
                </li>
            }

            <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                <button type="button"
                        class="page-link"
                        disabled="@(CurrentPage == TotalPages)"
                        @onclick="() => ChangePage(CurrentPage + 1)">
                    Next
                </button>
            </li>
        </ul>
    </div>
}

@code {
    private const int PageSize = 8;

    public IStoreRepository Repository => Service;

    public IEnumerable<Product> ProductData { get; set; } = Enumerable.Empty<Product>();
    public int TotalProducts { get; set; }
    public int TotalCategories { get; set; }
    public int CurrentPage { get; set; } = 1;
    public int TotalPages { get; set; } = 1;

    protected override async Task OnInitializedAsync()
    {
        await RefreshSummaryAsync();
        await LoadPageDataAsync();
    }

    public async Task RefreshSummaryAsync()
    {
        TotalProducts = await Repository.Products.CountAsync();
        TotalCategories = await Repository.Products
            .Where(p => !string.IsNullOrWhiteSpace(p.Category))
            .Select(p => p.Category)
            .Distinct()
            .CountAsync();

        TotalPages = Math.Max(1, (int)Math.Ceiling((decimal)TotalProducts / PageSize));
        if (CurrentPage > TotalPages)
        {
            CurrentPage = TotalPages;
        }
    }

    public async Task LoadPageDataAsync()
    {
        ProductData = await Repository.Products
            .AsNoTracking()
            .OrderBy(p => p.ProductId)
            .Skip((CurrentPage - 1) * PageSize)
            .Take(PageSize)
            .ToListAsync();
    }

    public async Task ChangePage(int pageNumber)
    {
        int targetPage = Math.Clamp(pageNumber, 1, TotalPages);
        if (targetPage == CurrentPage)
        {
            return;
        }

        CurrentPage = targetPage;
        await LoadPageDataAsync();
    }

    public async Task DeleteProduct(Product p)
    {
        Repository.DeleteProduct(p);
        await RefreshSummaryAsync();
        await LoadPageDataAsync();
    }

    public IEnumerable<int> GetVisiblePages()
    {
        int start = Math.Max(1, CurrentPage - 2);
        int end = Math.Min(TotalPages, CurrentPage + 2);
        return Enumerable.Range(start, end - start + 1);
    }

    public string GetDetailsUrl(int id) => $"/admin/products/details/{id}";
    public string GetEditUrl(int id) => $"/admin/products/edit/{id}";
}
