@using Microsoft.AspNetCore.Components.Routing
@page "/admin/products/details/{id:int}"

@if (Product is null)
{
    <div class="alert alert-warning mb-0">Không tìm thấy sản phẩm.</div>
}
else
{
    <div class="d-flex flex-column flex-md-row justify-content-md-between align-items-md-center mb-4 gap-2">
        <div>
            <h3 class="mb-1 fw-semibold"><i class="fa-regular fa-eye me-2"></i>Product Details</h3>
            <div class="text-muted">Thông tin chi tiết sản phẩm #@Product.ProductId</div>
        </div>
        <span class="badge bg-primary rounded-pill px-3 py-2">@Product.Category</span>
    </div>

    <div class="table-responsive border rounded-3 mb-4">
        <table class="table table-striped mb-0">
            <tbody>
                <tr>
                    <th style="width: 180px">ID</th>
                    <td>@Product.ProductId</td>
                </tr>
                <tr>
                    <th>Name</th>
                    <td>@Product.Name</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>@Product.Description</td>
                </tr>
                <tr>
                    <th>Category</th>
                    <td>@Product.Category</td>
                </tr>
                <tr>
                    <th>Price</th>
                    <td class="fw-semibold">@Product.Price.ToString("C")</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div>
        <NavLink class="btn btn-warning me-2" href="@EditUrl">
            <i class="fa-regular fa-pen-to-square me-1"></i>Edit
        </NavLink>
        <NavLink class="btn btn-secondary" href="/admin/products">
            <i class="fa-solid fa-arrow-left me-1"></i>Back
        </NavLink>
    </div>
}

@code {
    [Inject]
    public IStoreRepository? Repository { get; set; }

    [Parameter]
    public int Id { get; set; }

    public Product? Product { get; set; }

    protected override void OnParametersSet()
    {
        Product = Repository?.Products.FirstOrDefault(p => p.ProductId == Id);
    }

    public string EditUrl => $"/admin/products/edit/{Product?.ProductId}";
}
