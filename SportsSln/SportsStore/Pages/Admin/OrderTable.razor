<div class="mb-2 d-flex justify-content-between align-items-center">
    <h5 class="mb-0 fw-semibold">@TableTitle</h5>
    <span class="badge bg-secondary rounded-pill">@Orders.Count() orders</span>
</div>

<div class="table-responsive border rounded-3">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Customer</th>
                <th>Address</th>
                <th>Items</th>
                <th style="width: 140px" class="text-end">Action</th>
            </tr>
        </thead>
        <tbody>
            @if (Orders?.Count() > 0)
            {
                @foreach (Order o in Orders)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@o.Name</div>
                            <div class="small text-muted">Order #@o.OrderID</div>
                        </td>
                        <td>
                            <div class="small">@o.Line1</div>
                            <div class="small text-muted">@o.City, @o.Country</div>
                            <div class="small text-muted">@o.Zip</div>
                        </td>
                        <td>
                            @if (o.Lines.Any())
                            {
                                <ul class="list-unstyled mb-0">
                                    @foreach (CartLine line in o.Lines)
                                    {
                                        <li class="small d-flex justify-content-between gap-2 py-1 border-bottom">
                                            <span>@line.Product.Name</span>
                                            <span class="badge bg-light text-dark border">x@line.Quantity</span>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted small">No items</span>
                            }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm @ButtonClass"
                                    @onclick="@(e => OrderSelected.InvokeAsync(o.OrderID))">
                                @ButtonLabel
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center py-4 text-muted">No Orders</td></tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter]
    public string TableTitle { get; set; } = "Orders";

    [Parameter]
    public IEnumerable<Order> Orders { get; set; } = Enumerable.Empty<Order>();

    [Parameter]
    public string ButtonLabel { get; set; } = "Ship";

    [Parameter]
    public string ButtonClass { get; set; } = "btn-danger";

    [Parameter]
    public EventCallback<int> OrderSelected { get; set; }
}
