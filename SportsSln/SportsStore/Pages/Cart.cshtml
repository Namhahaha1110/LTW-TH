@page
@model CartModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 fw-bold"><i class="bi bi-cart3 me-2"></i>Your cart</h2>
    <a class="btn btn-outline-primary" href="@Model?.ReturnUrl">
        <i class="bi bi-arrow-left me-1"></i>Continue shopping
    </a>
</div>

<div class="table-responsive border rounded-3 mb-4">
<table class="table table-striped align-middle mb-0">
    <thead>
        <tr>
            <th>Quantity</th>
            <th>Item</th>
            <th class="text-end">Price</th>
            <th class="text-end">Subtotal</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var line in Model?.Cart?.Lines ?? Enumerable.Empty<CartLine>())
        {
            <tr>
                <td class="text-center">@line.Quantity</td>
                <td class="text-start">@line.Product.Name</td>
                <td class="text-end">@line.Product.Price.ToString("c")</td>
                <td class="text-end">@((line.Quantity * line.Product.Price).ToString("c"))</td>
                <td class="text-center">
                    <form asp-page-handler="Remove" method="post">
                        <input type="hidden" name="productId" value="@line.Product.ProductId" />
                        <input type="hidden" name="returnUrl" value="@Model?.ReturnUrl" />
                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="3" class="text-end fw-semibold">Total:</td>
            <td class="text-end fw-bold text-primary">@Model?.Cart?.ComputeTotalValue().ToString("c")</td>
        </tr>
    </tfoot>
</table>
</div>

<div class="text-center">
    <a class="btn btn-outline-primary me-2" href="@Model?.ReturnUrl">Continue shopping</a>
    <a class="btn btn-primary" asp-action="Checkout" asp-controller="Order">
        <i class="bi bi-credit-card me-1"></i>Checkout
    </a>
</div>
