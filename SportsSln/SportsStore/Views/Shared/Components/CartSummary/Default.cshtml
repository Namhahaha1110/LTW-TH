@model Cart

<div>
    @if (Model?.Lines.Count() > 0)
    {
        <span class="badge rounded-pill bg-light text-dark border px-3 py-2 me-2">
            <i class="bi bi-receipt-cutoff me-1"></i>
            @Model.Lines.Sum(x => x.Quantity) item(s) • @Model.ComputeTotalValue().ToString("c")
        </span>
    }

    <a class="btn btn-warning btn-sm rounded-pill px-3 fw-semibold"
       asp-page="/Cart"
       asp-route-returnurl="@ViewContext.HttpContext.Request.PathAndQuery()">
        <i class="bi bi-cart3 me-1"></i>Cart
    </a>
</div>
