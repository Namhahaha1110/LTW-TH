@model IEnumerable<string>

<div class="list-group category-menu">
    <a class="list-group-item list-group-item-action d-flex align-items-center @(ViewBag.SelectedCategory == null ? "active" : "")"
       asp-action="Index"
       asp-controller="Home"
       asp-route-category=""
       asp-route-productPage="1">
        <i class="bi bi-house-door-fill me-2"></i>Home
    </a>

    @foreach (string category in Model ?? Enumerable.Empty<string>())
    {
        <a class="list-group-item list-group-item-action d-flex align-items-center @(category == ViewBag.SelectedCategory ? "active" : "")"
           asp-action="Index"
           asp-controller="Home"
           asp-route-category="@category"
           asp-route-productPage="1">
            <i class="bi bi-tag-fill me-2"></i>@category
        </a>
    }
</div>
