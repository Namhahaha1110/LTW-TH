<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>SportsStore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/css/all.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link href="/css/site.css" rel="stylesheet">
</head>
<body class="storefront">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-action="Index" asp-controller="Home">
                <i class="bi bi-bag-fill me-2"></i>SPORTS STORE
            </a>
            <div class="ms-auto d-flex align-items-center">
                <vc:cart-summary />
            </div>
        </div>
    </nav>

    <div class="container-fluid py-4">
        <div class="row g-4">
            <aside id="categories" class="col-12 col-lg-3" data-aos="fade-right">
                <div class="card border-0 shadow-sm category-card">
                    <div class="card-header bg-white fw-semibold">
                        <i class="bi bi-grid-fill me-2"></i>Danh mục sản phẩm
                    </div>
                    <div class="card-body p-2">
                        <vc:navigation-menu />
                    </div>
                </div>
            </aside>

            <section class="col-12 col-lg-9" data-aos="fade-up">
                @RenderBody()
            </section>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ once: true, duration: 550, offset: 40 });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>