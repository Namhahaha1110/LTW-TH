<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"] - SportsStore</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body { background: #f6f7fb; }
        .app-shell { max-width: 1100px; }
        .brand-dot { width: 10px; height: 10px; border-radius: 999px; display:inline-block; margin-right:10px; }
        .sidebar-card { position: sticky; top: 16px; }
        .muted { color: #6c757d; }
        .card-soft { border: 0; border-radius: 16px; box-shadow: 0 8px 24px rgba(16,24,40,.06); }
        .btn-page { border-radius: 12px; }
    </style>
</head>

<body>
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
        <div class="container app-shell py-2">
            <span class="brand-dot bg-primary"></span>
            <a class="navbar-brand fw-bold mb-0" href="/">SportsStore</a>

            <div class="ms-auto d-flex align-items-center gap-2">
                <span class="badge text-bg-light border">Buổi 03</span>
            </div>
        </div>
    </nav>

    <main class="container app-shell my-4">
        <div class="row g-4">
            <aside class="col-12 col-lg-3">
                <div class="card card-soft sidebar-card">
                    <div class="card-body">
                        <h6 class="fw-semibold mb-2">Danh mục</h6>
                        <p class="muted mb-3">Chưa làm Category (sẽ làm sau).</p>

                        <div class="d-grid gap-2">
                            <button class="btn btn-outline-secondary btn-sm" disabled>Watersports</button>
                            <button class="btn btn-outline-secondary btn-sm" disabled>Soccer</button>
                            <button class="btn btn-outline-secondary btn-sm" disabled>Chess</button>
                        </div>

                        <hr class="my-3" />

                        <small class="muted">
                            Gợi ý: Buổi sau có thể làm filter theo Category + route đẹp.
                        </small>
                    </div>
                </div>
            </aside>

            <section class="col-12 col-lg-9">
                @RenderBody()
            </section>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>